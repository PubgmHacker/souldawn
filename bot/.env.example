# SOULDAWN Bot — Environment Variables
# Copy to bot/.env and fill in values. НИКОГДА не коммить реальные значения.

# ═══════════════════ REQUIRED ═══════════════════
# Токен бота от @BotFather
BOT_TOKEN=

# ═══════════════════ TELEGRAM LOGIN (optional) ═══════════════════
# Тот же токен, что и BOT_TOKEN. Нужен, пока бот выпускает JWT сам.
# После перехода авторизации на web/ можно оставить пустым.
TG_LOGIN_BOT_TOKEN=

# ═══════════════════ AI (optional) ═══════════════════
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# ═══════════════════ YOOKASSA PAYMENT (optional) ═══════════════════
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=

# ═══════════════════ SERVER ═══════════════════
WEBHOOK_PORT=8080
WEBHOOK_SECRET=
# URL Next.js-сайта (web/), куда бот шлёт заказы/тикеты
SITE_URL=

# ═══════════════════ DATABASE ═══════════════════
# Railway проставляет автоматически при добавлении PostgreSQL.
# Бот сам конвертирует postgres:// → postgresql+asyncpg://
DATABASE_URL=

# ═══════════════════ ADMINS ═══════════════════
# Telegram user id через запятую (роль admin/owner в БД ставится по этому списку)
ADMIN_IDS=

# ═══════════════════ MINIAPP ═══════════════════
# URL облегчённой мини-аппы (GitHub Pages или статика). Пусто = открыть web/ как WebApp.
MINIAPP_URL=

# ═══════════════════ SUPPORT ═══════════════════
# Чат/канал, куда падают новые тикеты операторам
SUPPORT_CHAT_ID=
REVIEW_CHANNEL_URL=

# ═══════════════════ ОСНОВНОЙ КАНАЛ (ОБЯЗАТЕЛЬНАЯ ПОДПИСКА) ══════════════
# Для проверки подписки бот ДОЛЖЕН быть администратором канала.
# CHANNEL_ID — числовой id (напр. -1001234567890) или @username канала.
# Пусто = gate отключён.
CHANNEL_ID=
# @username канала без https (для ссылки-кнопки, если CHANNEL_URL не задан)
CHANNEL_USERNAME=
# Прямая ссылка на канал (приоритетней CHANNEL_USERNAME)
CHANNEL_URL=
# Раз в сколько ответов бота показывать напоминание (по умолчанию 5)
CHANNEL_REMIND_EVERY=5
