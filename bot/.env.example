# SOULDAWN Bot — Environment Variables
# Copy to bot/.env and fill in values. НИКОГДА не коммить реальные значения.

# ═══════════════════ REQUIRED ═══════════════════
# Токен бота от @BotFather (главного бота SOULDAWN)
BOT_TOKEN=

# ═══════════════════ SITE (RAILWAY) ═══════════════════
# Публичный URL Next.js-сайта (web/) на Railway.
# Бот прокидывает этот адрес в миниапп (?site=...), чтобы миниапп
# мог обращаться к API сайта (/api/auth/mini-app, /api/products и т.д.).
# Пример: https://souldawn-production.up.railway.app
SITE_URL=

# ═══════════════════ MINIAPP (GITHUB PAGES) ═══════════════════
# URL каталог-миниаппы на GitHub Pages. Бот открывает её как WebApp.
# Пример: https://pubgmhacker.github.io/ihgdtyhfjkhlkjyktdhfgjbjnkj/
MINIAPP_URL=
# URL FAQ-миниаппы на GitHub Pages (обычно тот же репо + /faq/).
# Пример: https://pubgmhacker.github.io/ihgdtyhfjkhlkjyktdhfgjbjnkj/faq/
FAQ_MINIAPP_URL=

# ═══════════════════ SUPPORT BOT ═══════════════════
# Ссылка на отдельного бота поддержки (инлайн-кнопка «Поддержка»).
# Пример: https://t.me/souldawn_support_bot
SUPPORT_BOT_URL=
# Чат/канал, куда падают новые тикеты операторам (числовой id)
SUPPORT_CHAT_ID=

# ═══════════════════ TELEGRAM LOGIN (optional) ═══════════════════
# Тот же токен, что и BOT_TOKEN. Нужен, пока бот выпускает JWT сам.
TG_LOGIN_BOT_TOKEN=

# ═══════════════════ AI (optional) ═══════════════════
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# ═══════════════════ YOOKASSA PAYMENT (optional) ═══════════════════
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=

# ═══════════════════ SERVER ═══════════════════
WEBHOOK_PORT=8080
WEBHOOK_SECRET=

# ═══════════════════ DATABASE ═══════════════════
# Railway проставляет автоматически при добавлении PostgreSQL.
# Бот сам конвертирует postgres:// → postgresql+asyncpg://
DATABASE_URL=

# ═══════════════════ ADMINS ═══════════════════
# Telegram user id через запятую (роль admin/owner в БД ставится по этому списку)
ADMIN_IDS=

# ═══════════════════ OTHER ═══════════════════
REVIEW_CHANNEL_URL=

# ═══════════════════ ОСНОВНОЙ КАНАЛ (ОБЯЗАТЕЛЬНАЯ ПОДПИСКА) ══════════════
# Для проверки подписки бот ДОЛЖЕН быть администратором канала.
# CHANNEL_ID — числовой id (напр. -1001234567890) или @username канала.
# Пусто = gate отключён.
CHANNEL_ID=
# @username канала без https (для ссылки-кнопки, если CHANNEL_URL не задан)
CHANNEL_USERNAME=
# Прямая ссылка на канал (приоритетней CHANNEL_USERNAME)
CHANNEL_URL=
# Раз в сколько ответов бота показывать напоминание (по умолчанию 5)
CHANNEL_REMIND_EVERY=5
