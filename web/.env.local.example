# SOULDAWN Web (Next.js) — Environment Variables
# Скопируй в .env.local и заполни. НИКОГДА не коммить реальные значения.

# ═════════════════ REQUIRED ═══════════════════

# Токен бота от @BotFather (тот же, что и у bot/).
# Сайт проверяет подписи Telegram initData и Login Widget через этот токен.
# Если не задан TELEGRAM_BOT_TOKEN — сайт попытается взять BOT_TOKEN.
# ОБАЯЗАТЕЛЬНО один из них должен быть заполнен, иначе авторизация не работает.
BOT_TOKEN=
TELEGRAM_BOT_TOKEN=

# Секрет JWT-сессий сайта. Сгенерируй: openssl rand -base64 32
JWT_SECRET=

# ═════════════════ DATABASE ═══════════════════
# Postgres. Railway проставляет автоматически. Prisma работает с postgresql:// напрямую.
DATABASE_URL=

# ═══════════════════ TELEGRAM ═════════════════
# Username бота БЕЗ @ (для Login Widget).
# ВАЖНО: настрой в @BotFather → /setdomain <твой-домен> для этого бота,
# иначе Login Widget выдаст ошибку "Username Invalid" на сайте.
NEXT_PUBLIC_TELEGRAM_BOT_NAME=

# ═══════════════════ MINIAPP CORS ═══════════════════
# Origins миниаппа (через запятую), которым разрешены cross-origin запросы к API.
# Нужен если миниапп хостится не на том же домене, что сайт.
# Пример: https://username.github.io,https://example.pages.dev
# Используй * для разрешения с любого origin (не рекомендуется для прода).
ALLOWED_MINIAPP_ORIGINS=

# ═════════════════ SITE ═══════════════════
# Публичный URL сайта (для webhook, CORS, redirect). Например https://souldawn.example.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ═════════════════ YOOKASSA PAYMENT (optional) ═══════════════════
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=

# ═════════════════ APPLE SIGN-IN (optional) ═══════════════════
# Service ID (client_id) из Apple Developer.
APPLE_CLIENT_ID=

# ═════════════════ VK OAUTH (optional) ═══════════════════
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# ═════════════════ ADMINS ═══════════════════
# Telegram user id через запятую — этим юзерам выдаётся роль admin.
ADMIN_IDS=

# ═════════════════ OPTIONAL ═══════════════════
NODE_ENV=development
