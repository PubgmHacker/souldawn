# SOULDAWN Web (Next.js) — Environment Variables
# Скопируй в .env.local и заполни. НИКОГДА не коммить реальные значения.

# ═══════════════════ REQUIRED ═══════════════════

# Токен бота от @BotFather. Используется для верификации Telegram auth.
# Поддерживает оба имени: BOT_TOKEN и TELEGRAM_BOT_TOKEN.
BOT_TOKEN=
TELEGRAM_BOT_TOKEN=

# Секрет JWT-сессий сайта. Сгенерируй: openssl rand -base64 32
JWT_SECRET=

# ═══════════════════ DATABASE ═══════════════════
DATABASE_URL=

# ═══════════════════ TELEGRAM ═══════════════════
# Username бота БЕЗ @ (для Login Widget).
# ВАЖНО: без этой переменной виджет покажет «Username Invalid».
# Настрой в BotFather: /setdomain → укажи домен сайта.
NEXT_PUBLIC_TELEGRAM_BOT_NAME=

# ═══════════════════ SITE ═══════════════════
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ═══════════════════ YOOKASSA ═══════════════════
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=

# Секрет для проверки webhook YooKassa (Authorization: Bearer <secret>). ОБЯЗАТЕЛЕН.
WEBHOOK_SECRET=

# ═══════════════════ СДЭК (доставка) ════════════════
# Боевой API: https://api.cdek.ru/v2 ; тест: https://api.edu.cdek.ru/v2
CDEK_API_URL=https://api.cdek.ru/v2
CDEK_ACCOUNT=
CDEK_PASSWORD=
# Код города-отправителя СДЭК (44 = Москва).
CDEK_FROM_CITY_CODE=44
# Тарифы: 136 = склад-склад (ПВЗ). 
CDEK_TARIFF_CODE=136
CDEK_TARIFF_PVZ=136

# ═══════════════════ ЯНДЕКС.КАРТЫ ════════════════
# Ключ JavaScript API Яндекс.Карт (developer.tech.yandex.ru). Нужен для выбора ПВЗ на карте.
NEXT_PUBLIC_YANDEX_MAPS_KEY=

# ═══════════════════ APPLE SIGN-IN (optional) ═══════════════════
APPLE_CLIENT_ID=

# ═══════════════════ VK OAUTH (optional) ═══════════════════
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# ═══════════════════ ADMINS ═══════════════════
# Telegram user id через запятую — этим юзерам выдаётся роль admin.
ADMIN_IDS=

# ═══════════════════ REVIEWS ═══════════════════
# @username канала отзывов (без @). Используется в /api/reviews.
REVIEW_CHANNEL_USERNAME=

# ═══════════════════ OPTIONAL ═══════════════════
NODE_ENV=development
