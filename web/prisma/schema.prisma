generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  telegramId    Int?      @unique
  email         String?   @unique
  username      String    @default("")
  fullName      String    @default("")
  role          String    @default("user")
  isAdmin       Boolean   @default(false)
  isActive      Boolean   @default(true)
  profileData   String    @default("{}")
  notifyNewDrops Boolean  @default(true)
  notifyPromos  Boolean  @default(true)
  lastLogin     DateTime?
  lastSeen      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  identities  Identity[]
  orders       Order[]
  tgSessions   TgSession[]
  notifications Notification[]
}

model Identity {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  providerUid  String
  passwordHash String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUid])
}

model Order {
  id            String   @id @default(cuid())
  cipher        String   @unique
  userId        String?
  userEmail     String
  userTelegram  String
  userName      String   @default("")
  userPhone     String   @default("")
  items         String
  itemNames     String   @default("")
  itemsCount    Int      @default(0)
  subtotal      Int      @default(0)
  deliveryCost  Int      @default(0)
  discountAmount Int     @default(0)
  promoCode     String   @default("")
  total         Int      @default(0)
  deliveryType  String   @default("cdek-pvz")
  deliveryCity  String   @default("")
  deliveryAddress String  @default("")
  pvzCode       String   @default("")
  pvzAddress    String   @default("")
  comment       String   @default("")
  status        String   @default("pending")
  paidAt        DateTime?
  trackingCode  String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([cipher])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model TgSession {
  id        String   @id @default(cuid())
  userId    String
  rawData   String
  authDate  Int
  hash      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("info")
  isRead    Boolean   @default(false)
  createdBy String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model BroadcastTemplate {
  id           String   @id @default(cuid())
  type         String   @unique
  name         String
  bodyTemplate String
  hasPhoto     Boolean  @default(false)
  photoUrl     String   @default("")
  hasVideo     Boolean  @default(false)
  videoUrl     String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Broadcast {
  id           String   @id @default(cuid())
  templateType String
  title        String
  body         String
  photoUrl     String   @default("")
  videoUrl     String   @default("")
  sentBy       String
  sentCount    Int      @default(0)
  status       String   @default("draft")
  createdAt    DateTime @default(now())
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  verified  Boolean  @default(false)
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}